# Enables Claude ranking + synthesis. Without it, gttp falls back to a
# deterministic heuristic synthesizer (still produces pages, just less polished).
ANTHROPIC_API_KEY=

# Enable live Reddit search (script-app credentials from
# https://www.reddit.com/prefs/apps). Without these, use `gttp build --offline`
# to run from bundled fixtures.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=gttp/0.1 (self-help summary curator)
